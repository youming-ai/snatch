{
	"name": "snatch",
	"private": true,
	"packageManager": "bun@1.3.14",
	"workspaces": [
		"packages/*"
	],
	"scripts": {
		"dev": "bun --filter '@snatch/web' dev",
		"dev:api": "bun --filter '@snatch/api' dev",
		"build": "bun --filter '@snatch/shared' typecheck && bun --filter '@snatch/api' build && bun --filter '@snatch/web' build",
		"build:api": "bun --filter '@snatch/shared' typecheck && bun --filter '@snatch/api' build",
		"build:web": "bun --filter '@snatch/web' build",
		"build:cf": "bun --filter '@snatch/shared' typecheck && bun --filter '@snatch/web' build",
		"deploy:cf": "bunx wrangler@4 pages deploy packages/web/dist/client --project-name=snatch",
		"preview": "bun --filter '@snatch/web' preview",
		"test": "bun --filter '*' test",
		"test:shared": "bun --filter '@snatch/shared' test",
		"test:api": "bun --filter '@snatch/api' test",
		"test:web": "bun --filter '@snatch/web' test",
		"typecheck": "bun --filter '*' typecheck",
		"lint": "biome check .",
		"lint:fix": "biome check --fix .",
		"format": "biome format --write .",
		"check": "biome check --fix .",
		"docker:up": "docker compose up -d --build",
		"docker:down": "docker compose down",
		"prepare": "lefthook install"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.5.5",
		"@types/bun": "latest",
		"lefthook": "^2.1.10"
	}
}
