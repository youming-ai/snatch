# ===========================================
# Snatch - Environment Configuration
# ===========================================
# Copy this file to .env and modify as needed

# ===========================================
# Local development (packages/web)
# ===========================================

# API backend URL for local `bun dev` (non-Docker)
API_URL=http://localhost:3001

# ===========================================
# Docker Compose / Dokploy
# ===========================================

# Host ports for local `docker compose up`. Dokploy ignores these
# when you route via its built-in Traefik reverse proxy.
WEB_PORT=38700
API_PORT=38701

# Internal SSR → API URL (container network). In docker-compose this
# resolves to the `api` service via the shared `snatch` network.
# The web SSR layer proxies download streams from this URL, so the API
# does not need a public domain — single-origin deployments work.
API_URL_INTERNAL=http://api:3001

# CORS — comma-separated list of web origins allowed to call the API.
# In production set to the web app's public URL (e.g., https://snatch.example.com).
# Leave empty to reject all cross-origin requests (secure default).
ALLOWED_ORIGINS=

# ===========================================
# Web SSR rate limiting (packages/web)
# ===========================================
# Read by Astro/Vite via import.meta.env in packages/web/src/config/env.ts.
# The `PUBLIC_` prefix is required for Astro to expose them.
# Applied in the web SSR /api/download endpoint (per-IP request cap).
PUBLIC_RATE_LIMIT_MAX=10
PUBLIC_RATE_LIMIT_WINDOW=60000
