# ===========================================
# Snatch - Environment Configuration
# ===========================================
# Copy this file to .env and modify as needed.
#
# Architecture: a single Hono app serves the built TanStack Start static client
# and the /api routes on one origin, resolving and processing media via yt-dlp + ffmpeg.

# ===========================================
# Docker Compose / Dokploy
# ===========================================

# Host port for the app (serves UI + API). Dokploy ignores this when routing
# via its built-in Traefik reverse proxy.
APP_PORT=38700

# CORS — comma-separated web origins allowed to call /api cross-origin.
# The all-in-one Docker build serves the SPA same-origin and needs none
# (leave empty to reject all cross-origin requests — secure default).
# SPLIT DEPLOYMENT: set this to the Cloudflare Pages origin of the frontend,
# e.g. ALLOWED_ORIGINS=https://snatch.pages.dev
ALLOWED_ORIGINS=

# ===========================================
# API rate limiting
# ===========================================
API_RATE_LIMIT_MAX=30
API_RATE_LIMIT_WINDOW=60000

# ===========================================
# Observability
# ===========================================
# Pino threshold for API request/error logs.
LOG_LEVEL=info
# API Sentry DSN. Leave empty to disable API error reporting.
SENTRY_DSN=

# ===========================================
# Security
# ===========================================
# Optional API key to gate /api/* on a self-hosted instance. When unset (the
# default) the API is public. When set, requests must send
# `Authorization: Api-Key <value>` — the web client's Settings drawer does.
API_KEY=

# Secret key used to HMAC-sign resolved media URLs before returning them to
# the client. Protects the proxy and download endpoints.
# If empty, a random key is generated in memory at startup. For multi-replica
# or restart-stable production deployments, set this to a fixed secret.
PROXY_SIGNING_KEY=

# ===========================================
# Local frontend dev (packages/web)
# ===========================================
# Where the Vite dev server proxies /api during `bun dev`. Defaults to the
# local API. No effect on the production build (SPA is same-origin).
VITE_API_TARGET=http://localhost:3001

# ===========================================
# Frontend build (packages/web)
# ===========================================
# SPLIT DEPLOYMENT only: absolute origin of the API, baked into the static client
# at build time. Set this in the Cloudflare Pages build environment so the
# static frontend calls the Dokploy-hosted API, e.g.
# VITE_API_BASE_URL=https://api.snatch.example
# Leave unset for the all-in-one Docker build (client is served same-origin).
VITE_API_BASE_URL=

# Browser Sentry DSN, baked into the static client. Leave empty to disable
# browser error reporting.
VITE_SENTRY_DSN=
