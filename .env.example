# ===========================================
# Snatch - Environment Configuration
# ===========================================
# Copy this file to .env and modify as needed

# ===========================================
# Frontend (apps/web)
# ===========================================

# API backend URL
# Local dev: http://localhost:3001 (cargo run) or http://localhost:38701 (Docker)
RUST_API_URL=http://localhost:38701

# ===========================================
# API (apps/api)
# ===========================================

# CORS allowed origins (comma-separated)
# Leave empty for development, set for production
# Example: https://snatch.example.com
ALLOWED_ORIGINS=

# Server port (internal, mapped to 38701 via Docker)
PORT=3001

# Log level: error, warn, info, debug
RUST_LOG=info

# ===========================================
# Rate Limiting
# ===========================================

# Window in milliseconds (default: 60000 = 1 minute)
RATE_LIMIT_WINDOW=60000

# Max requests per window
RATE_LIMIT_MAX=10
