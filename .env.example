# ===========================================
# Snatch - Environment Configuration
# ===========================================
# Copy this file to .env and modify as needed.
#
# Architecture: a single Hono app serves the built React SPA and the /api
# routes on one origin, resolving media via an internal cobalt service.

# ===========================================
# Docker Compose / Dokploy
# ===========================================

# Host port for the app (serves UI + API). Dokploy ignores this when routing
# via its built-in Traefik reverse proxy.
APP_PORT=38700

# CORS — comma-separated web origins allowed to call /api cross-origin.
# The bundled same-origin SPA needs none; leave empty to reject all
# cross-origin requests (secure default). Set this only if a DIFFERENT origin
# must call the API.
ALLOWED_ORIGINS=

# ===========================================
# API rate limiting
# ===========================================
API_RATE_LIMIT_MAX=30
API_RATE_LIMIT_WINDOW=60000

# ===========================================
# Media engine — cobalt
# ===========================================
# Internal URL of the self-hosted cobalt instance used to resolve and stream
# the actual media file. In docker-compose this resolves to the `cobalt`
# service. For local `bun dev:api` outside Docker, run cobalt on :9000.
COBALT_API_URL=http://localhost:9000

# ===========================================
# Local frontend dev (packages/web)
# ===========================================
# Where the Vite dev server proxies /api during `bun dev`. Defaults to the
# local API. No effect on the production build (SPA is same-origin).
VITE_API_TARGET=http://localhost:3001
